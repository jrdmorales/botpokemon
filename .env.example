# --- Base de datos ---
POSTGRES_USER=pokeprecio
POSTGRES_PASSWORD=cambiar-en-produccion
POSTGRES_DB=pokeprecio
# Para correr backend fuera de Docker:
DATABASE_URL=postgresql+asyncpg://pokeprecio:cambiar-en-produccion@192.168.1.100:5432/pokeprecio

# --- Telegram ---
# Token de @BotFather
TELEGRAM_BOT_TOKEN=
# Chat ID del canal/grupo de administración (alertas de salud de scrapers)
TELEGRAM_ADMIN_CHAT_ID=

# --- API ---
# Clave para los endpoints /admin/* (match-queue, scraper-health)
ADMIN_API_KEY=cambiar-en-produccion

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://192.168.1.100:8000
